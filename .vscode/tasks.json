{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build APK",
            "type": "shell",
            "command": "cmd",
            "args": ["/c", "${workspaceFolder}\\build-apk.cmd"],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Install Debug",
            "type": "shell",
            "command": "cmd",
            "args": ["/c", "${workspaceFolder}\\install-debug.cmd"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "echo",
            "type": "shell",
            "command": "echo Hello"
        }
    ]
}
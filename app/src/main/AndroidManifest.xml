<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".ThorApplication"
        android:label="Ayn Thor Launcher"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:supportsRtl="true">

        <activity
            android:name=".InteractionHostActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:launchMode="singleTask"
            android:taskAffinity=""
            android:theme="@style/Theme.ThorLauncher.Host">
            <intent-filter android:priority="999">
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.ThorLauncher.Host" />

        <activity
            android:name=".PresentationHostActivity"
            android:launchMode="singleTop"
            android:excludeFromRecents="true"
            android:resizeableActivity="true"
            android:taskAffinity="com.launcher.aynthords.secondary"
            android:exported="true"
            android:theme="@style/Theme.ThorLauncher.Host">

            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.SECONDARY_HOME" />
            </intent-filter>
        </activity>

        <!--
          Threat model: remains exported only for framework media-button delivery.
          Guard with MEDIA_CONTENT_CONTROL so arbitrary third-party apps cannot inject
          media-button broadcasts into this receiver.
          TODO(security): migrate to in-app key handling (e.g., MediaSession callback) and set
          exported=false once framework broadcast dependency is removed.
        -->
        <receiver
            android:name=".library.PackageChangeReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_ADDED" />
                <action android:name="android.intent.action.PACKAGE_REMOVED" />
                <action android:name="android.intent.action.PACKAGE_CHANGED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <receiver
            android:name=".OdinKeyReceiver"
            android:exported="true"
            android:permission="android.permission.MEDIA_CONTENT_CONTROL">
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_BUTTON" />
            </intent-filter>
        </receiver>

    </application>
</manifest>

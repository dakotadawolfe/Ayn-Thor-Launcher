<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:label="Ayn Thor Launcher"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:supportsRtl="true">

        <!--
          Threat model: this entry point is intentionally exported because the system resolver
          must be able to launch it as the default HOME activity. Keep the intent filter minimal
          (MAIN + HOME only) so this activity is not advertised as a generic launcher target.
        -->
        <activity
            android:name=".PrimaryHomeActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:launchMode="singleTask"
            android:taskAffinity=""
            android:theme="@style/Theme.ThorLauncher.AppCompat">
            <intent-filter android:priority="999">
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
            </intent-filter>
        </activity>

        <!--
          Threat model: secondary-home is exported for system-managed multi-display home flows.
          Restrict categories to SECONDARY_HOME only; no generic DEFAULT routing.
        -->
        <activity
            android:name=".SecondaryHomeActivity"
            android:launchMode="singleTop"
            android:excludeFromRecents="true"
            android:resizeableActivity="true"
            android:taskAffinity="com.launcher.aynthords.secondary"
            android:exported="true"
            android:theme="@style/Theme.AynThorLauncher.SecondaryDebug">

            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.SECONDARY_HOME" />
            </intent-filter>
        </activity>

        <!--
          Threat model: remains exported only for framework media-button delivery.
          Guard with MEDIA_CONTENT_CONTROL so arbitrary third-party apps cannot inject
          media-button broadcasts into this receiver.
          TODO(security): migrate to in-app key handling (e.g., MediaSession callback) and set
          exported=false once framework broadcast dependency is removed.
        -->
        <receiver
            android:name=".OdinKeyReceiver"
            android:exported="true"
            android:permission="android.permission.MEDIA_CONTENT_CONTROL">
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_BUTTON" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
